#!/usr/bin/env bash
#
# Create or update the virtualenv for globally-available Python applications.

set -e -o pipefail

requirements_file="${1:-$HOME/.config/shell-scripts/requirements-global.txt}"

if [ ! -e "$requirements_file" ]; then
    echo "Requirements file not found: $requirements_file" >&2
    exit 1
fi

echo "Using requirements file $requirements_file"
mkvenv "$HOME/venv" -r "$requirements_file" "$@"
